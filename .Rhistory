library(ggplot2)
library(aplot)
library(aplotExtra)
library(ggfun)
#' Generate a customized oncoplot with clinical tracks
#' @param maf A MAF object from maftools
#' @param genes Number of top genes (numeric) or a vector of gene symbols (character)
#' @param clinical_vars List defining variables and types, e.g., list(FAB_classification="discrete")
#' @export
oncoplot <- function(maf, genes = 20, clinical_vars = NULL, n_breaks = 5, colors = NULL) {
# 这里的 genes 参数现在可以支持 get_oncoplot_genes 的逻辑
p_main <- oncoplot_main(maf, genes)
p_top <- aplotExtra:::oncoplot_sample(maf, genes)
p_right <- aplotExtra:::oncoplot_gene(maf, genes, ylab = 'percentage')
p_spacer <- ggplot() + ggfun::theme_transparent()
# 3. 基础组装 (使用 aplot 对齐)
pp <- p_main |>
aplot::insert_top(p_spacer, height = 0.02) |>
aplot::insert_top(p_top, height = 0.2) |>
aplot::insert_right(p_right, width = 0.2)
tracks <- oncoplot_clinical_track(maf, genes = genes, clinical_vars = clinical_vars,
n_breaks = n_breaks, colors = colors)
if (length(tracks) > 0) {
for (var in names(tracks)) {
pp <- aplot::insert_bottom(pp, tracks[[var]], height = 0.05)
}
}
return(pp)
}
#' @keywords internal
oncoplot_main <- function(maf, genes = 20) {
d <- aplotExtra:::oncoplot_tidy_onco_matrix(maf, genes)
ggplot(d, aes(x = .data$Sample, y = .data$Gene, fill = .data$Type)) +
geom_tile(colour = "white", linewidth = .01) +
theme_minimal() +
theme(
legend.position = "right",
axis.text.y.left = element_text(face = 'italic'),
axis.text.x = element_blank(),
axis.ticks.x = element_blank(),
panel.grid.major = element_blank(),
plot.margin = margin(t = 5, r = 2, b = 0, l = 5)) +
labs(fill = "Mutation Type")
}
oncoplot_clinical_track <- function(maf, genes = 20, clinical_vars, n_breaks, colors = NULL) { # nolint
if (is.null(clinical_vars)) return(list())
clinical_data <- maftools::getClinicalData(maf) |> as.data.frame()
var_names <- (if(is.list(clinical_vars)) names(clinical_vars) else clinical_vars) |>
intersect(colnames(clinical_data))
onco_matrix <- aplotExtra:::oncoplot_tidy_onco_matrix(maf, genes)
sample_order <- unique(as.character(onco_matrix$Sample))
df <- clinical_data[, c("Tumor_Sample_Barcode", var_names)]
df$Tumor_Sample_Barcode <- factor(df$Tumor_Sample_Barcode, levels = sample_order)
plot_list <- list()
for (var in var_names) {
tmp <- df[, c("Tumor_Sample_Barcode", var)]
colnames(tmp)[2] <- "value"
tmp$y_label <- var
tmp$value <- if (is.numeric(tmp$value)) {
binning_numeric(tmp$value, n_breaks = n_breaks)
} else {
as.factor(tmp$value)
}
p <- ggplot(tmp, aes(x = Tumor_Sample_Barcode, y = y_label, fill = value)) +
geom_tile(color = "white", linewidth = 0.01) +
theme_minimal() +
theme(
legend.position = "right",
axis.text.x = element_blank(),
axis.text.y = element_text(face = 'italic', color = "black", size = 10),
axis.ticks = element_blank(),
axis.title = element_blank(),  # nolint
panel.grid = element_blank(),
panel.background = element_blank(),
plot.margin = margin(t = 5, r = 2, b = 0, l = 5)
) +
labs(fill = var)
# 颜色（按变量单独控制）
if (!is.null(colors) && var %in% names(colors)) {
p <- p + scale_fill_manual(values = colors[[var]], na.value = "grey90")
}
plot_list[[var]] <- p
}
return(plot_list)
}
#' 将连续数值变量分段并美化标签
#' @param x numeric向量
#' @param n_breaks 分段数，默认5
#' @return factor，带美观区间标签
binning_numeric <- function(x, n_breaks = 5) {
if (!is.numeric(x)) return(as.factor(x))  # 如果不是数值，直接返回factor
# 使用 quantile 确保正好 n_breaks 个分段
probs <- seq(0, 1, length.out = n_breaks + 1)
brks <- quantile(x, probs = probs, na.rm = TRUE)
brks <- unique(brks)  # 去重，避免重复边界
binned <- cut(x, breaks = brks, include.lowest = TRUE)
# 美化标签：去掉小数点和括号，改为短横
lvls <- levels(binned)
lvls <- gsub("\\.0", "", lvls)          # 去掉小数
lvls <- gsub("\\(|\\]|\\]", "", lvls)   # 去掉括号
lvls <- gsub(",", "–", lvls)            # 用短横
levels(binned) <- lvls
return(binned)
}
laml.maf <- system.file("extdata", "tcga_laml.maf.gz", package = "maftools")
laml.clin <- system.file('extdata', 'tcga_laml_annot.tsv', package = 'maftools')
laml <- maftools::read.maf(maf = laml.maf, clinicalData = laml.clin)
var_names <- c("gender", "age")
laml.clin
var_names <- c("FAB_classification", "days_to_last_followup")
oncoplot(maf = laml, genes = 20, clinical_vars = var_names)
